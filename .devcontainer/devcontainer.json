{
    "name": "MagPlotter Dev Container",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    
    "postCreateCommand": "pip install -r requirements.txt",
    
    "postStartCommand": "nohup /workspaces/magplotter/scripts/start-watcher.sh > /dev/null 2>&1 &",
    
    "forwardPorts": [8000, 8888],
    
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    }
}
